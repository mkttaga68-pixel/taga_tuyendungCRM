# ============================================================
# Database — Postgres (dev: Neon free tier, https://neon.tech)
# ============================================================
DATABASE_URL="postgresql://user:password@ep-xxxx.neon.tech/taga_crm?sslmode=require"

# ============================================================
# Redis — (dev: Upstash free tier, https://upstash.com)
# ============================================================
REDIS_URL="rediss://default:password@xxxx.upstash.io:6379"

# ============================================================
# Auth (JWT)
# ============================================================
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ============================================================
# App
# ============================================================
NODE_ENV="development"
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"

# ============================================================
# Storage (CV/Attachment, dùng từ Sprint 3 cho CV nộp qua Landing Page).
# "local" = lưu đĩa trong STORAGE_LOCAL_DIR (chỉ dùng cho dev, không dùng
# production). "s3" = bật khi đã có bucket S3/MinIO thật (hoàn thiện ở Sprint 4).
# ============================================================
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage/uploads"
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ============================================================
# Facebook Conversions API (gửi sự kiện "Lead" server-to-server khi có form
# submit từ Landing Page) — thay cho việc hardcode plain-text trong
# ladipage-tuyendung-taga/google-apps-script.gs. Để trống nếu chưa dùng,
# IngestionService sẽ tự bỏ qua bước gửi CAPI.
# ============================================================
FB_PIXEL_ID=""
FB_ACCESS_TOKEN=""

# ============================================================
# Sprint 6 — node EMAIL (Resend) / SMS (Twilio) trong Automation Builder.
# apps/worker đọc trực tiếp qua process.env (load cùng file .env này).
# ============================================================
RESEND_API_KEY=""
EMAIL_FROM_ADDRESS=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# ============================================================
# Sprint 6 — Google Calendar/Meet OAuth (mỗi user tự connect tài khoản riêng,
# không dùng 1 service account chung). Tạo OAuth Client "Web application"
# trong Google Cloud Console, Redirect URI phải khớp chính xác giá trị dưới.
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4000/integrations/google/callback"

# ============================================================
# Next.js (biến public — sẽ bị bundle vào client, không đặt secret ở đây)
# ============================================================
NEXT_PUBLIC_API_URL="http://localhost:4000"
