# Chỉ dùng khi chạy `pnpm db:seed` lần đầu — đổi mật khẩu ngay sau khi đăng nhập.
SEED_ADMIN_EMAIL="admin@taga.local"
SEED_ADMIN_PASSWORD="ThayDoiMatKhauNgay123!"

# Facebook Conversions API — bỏ trống thì IngestionService chỉ log cảnh báo và
# bỏ qua bước gửi CAPI, không chặn việc lưu form_submission/candidate.
FB_PIXEL_ID=""
FB_ACCESS_TOKEN=""

# Sprint 6 — node EMAIL/SMS trong Automation. CHƯA CÓ giá trị thật — node sẽ
# báo lỗi rõ "chưa cấu hình" khi chạy cho tới khi điền API key thật vào đây.
RESEND_API_KEY=""
EMAIL_FROM_ADDRESS=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# Sprint 6 — Google Calendar/Meet OAuth (mỗi user tự connect tài khoản riêng).
# Cần tạo OAuth Client trong Google Cloud Console (loại "Web application"),
# Redirect URI phải khớp CHÍNH XÁC với GOOGLE_OAUTH_REDIRECT_URI bên dưới.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:4000/integrations/google/callback"

# Sprint 7 — GA4 Data API (rollup KPI hằng ngày). Dán NGUYÊN VĂN nội dung file
# JSON Service Account (1 dòng) — CHƯA CÓ giá trị thật, rollup vẫn chạy nhưng
# visitors/sessions/pageViews/bounceRate/avgTimeSeconds = 0 cho tới khi điền.
GOOGLE_GA4_SERVICE_ACCOUNT_JSON=""
