{
  "name": "taga-tuyendung-crm",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "pnpm --filter @taga-crm/api prisma generate",
    "db:migrate": "pnpm --filter @taga-crm/api prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @taga-crm/api prisma migrate deploy",
    "db:seed": "pnpm --filter @taga-crm/api exec ts-node prisma/seed.ts",
    "db:studio": "pnpm --filter @taga-crm/api prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
